# Copiá este archivo como .env y completá los valores

# ── APIs de datos USA ─────────────────────────────────────────
FINNHUB_API_KEY=tu_key_aqui
# Obtener en: https://finnhub.io (free tier: 60 req/min, sin tarjeta)

MARKETAUX_API_KEY=tu_key_aqui
# Obtener en: https://www.marketaux.com (free tier: 100 req/day, sin tarjeta)

ALPHA_VANTAGE_API_KEY=tu_key_aqui
# Obtener en: https://www.alphavantage.co (free tier: 25 req/day)
# Solo se usa como fallback si Finnhub no responde

# ── Mercado argentino ─────────────────────────────────────────
# BYMA no requiere API key — es pública: https://open.bymadata.com.ar/
# yfinance tampoco requiere key (para ^MERV y ADRs argentinos)

# ── IA ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=tu_key_aqui
# Claude Sonnet: análisis final y recomendaciones
# Obtener en: https://console.anthropic.com

OPENROUTER_API_KEY=tu_key_aqui
# Qwen3.6 gratis via OpenRouter: procesamiento de contexto
# Obtener en: https://openrouter.ai (sin tarjeta de crédito)
# Model: qwen/qwen3.6-plus-preview:free (1M tokens de contexto, gratis)

# ── App ──────────────────────────────────────────────────────
CACHE_TTL_MINUTES=30
NEWS_HOURS_BACK=24
LOG_LEVEL=INFO
